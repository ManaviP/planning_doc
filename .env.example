# Root reference template.
# Use backend/.env.example and frontend/.env.local.example for actual local files.
# Never commit backend/.env or frontend/.env.local.

# Backend (backend/.env)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
PROMETHEUS_URL=http://localhost:9090
API_BASE_URL=http://localhost:8000
# Optional synthetic fleet size when Prometheus is unavailable
# SYNTHETIC_NODE_COUNT=5

# Optional cloud deployment dispatch (backend/.env)
# GITHUB_REPOSITORY=owner/repo
# GITHUB_TOKEN=ghp_xxx
# GITHUB_DEPLOY_WORKFLOW=deploy.yml
# GITHUB_DEPLOY_REF=main

# Frontend (frontend/.env.local)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=http://localhost:8000
