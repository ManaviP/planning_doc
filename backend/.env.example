# Copy this file to backend/.env and provide real values.
# Never commit backend/.env.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
PROMETHEUS_URL=http://localhost:9090
API_BASE_URL=http://localhost:8000
# Optional synthetic fleet size when Prometheus is unavailable
# SYNTHETIC_NODE_COUNT=5

# Optional cloud deployment dispatch (Priority 2)
# GITHUB_REPOSITORY=owner/repo
# GITHUB_TOKEN=ghp_xxx
# GITHUB_DEPLOY_WORKFLOW=deploy.yml
# GITHUB_DEPLOY_REF=main

# Optional deployment gate controls
# BUDGET_LIMIT_USD=100
# CURRENT_MONTHLY_SPEND_USD=45
